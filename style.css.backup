:root {
    --bg: #F7FAFD;
    --card: rgba(255, 255, 255, .92);
    --border: rgba(44, 62, 80, .08);
    --text: #2C3E50;
    --muted: #6b7d94;
    --blue: #8FBEE6;
    --green: #7bb8a8;
    --orange: #d4a96a;
    --red: #E57C7C;
    --purple: #B2B1D8;
    --input-bg: rgba(247, 250, 253, .9);
    --radius: 10px;
    --glow1: rgba(178, 177, 216, .12);
    --glow2: rgba(143, 190, 230, .10);
    --h1-grad: linear-gradient(135deg, #8FBEE6, #B2B1D8, #c4b8e0);
    --card-h2: #3d4a5c;
    --paste-bg: rgba(178, 177, 216, .05);
    --paste-border: rgba(178, 177, 216, .35);
    --paste-hover: rgba(178, 177, 216, .10);
}

[data-theme="dark"] {
    --bg: #1A1F2B;
    --card: rgba(37, 44, 61, .90);
    --border: rgba(148, 163, 184, .12);
    --text: #E0E6ED;
    --muted: #94A3B8;
    --blue: #A5C9E8;
    --green: #7cc4a8;
    --orange: #d4a96a;
    --red: #D46A6A;
    --purple: #a8a3d0;
    --input-bg: rgba(30, 36, 50, .9);
    --glow1: rgba(165, 201, 232, .08);
    --glow2: rgba(168, 163, 208, .06);
    --h1-grad: linear-gradient(135deg, #A5C9E8, #a8a3d0, #c9b8e8);
    --card-h2: #b8c4d4;
    --paste-bg: rgba(165, 201, 232, .06);
    --paste-border: rgba(165, 201, 232, .25);
    --paste-hover: rgba(165, 201, 232, .10);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Inter', system-ui, sans-serif
}

body {
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden
}

.bg-glow {
    position: fixed;
    inset: 0;
    z-index: -1;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, var(--glow1), transparent),
        radial-gradient(ellipse 60% 50% at 80% 100%, var(--glow2), transparent), var(--bg);
    transition: background .4s ease
}

.app {
    max-width: 1320px;
    margin: 0 auto;
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 18px
}

.app-header {
    text-align: center;
    padding: 16px 0;
    position: relative
}

.app-header h1 {
    font-size: 26px;
    font-weight: 800;
    background: var(--h1-grad);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent
}

.app-header p {
    color: var(--muted);
    font-size: 13px;
    margin-top: 4px
}

/* Cards */
.card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 22px;
    backdrop-filter: blur(12px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, .06)
}

.card h2 {
    font-size: 16px;
    color: var(--card-h2);
    display: flex;
    align-items: center;
    gap: 8px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 16px
}

.card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 16px
}

.card-head h2 {
    border: none;
    padding: 0;
    margin: 0
}

.head-actions {
    display: flex;
    gap: 8px
}

/* Inputs */
.field {
    display: flex;
    flex-direction: column;
    gap: 5px
}

.field label {
    font-size: 12px;
    font-weight: 500;
    color: var(--muted)
}

input,
select {
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 9px 12px;
    color: var(--text);
    font-size: 14px;
    outline: none;
    transition: .25s
}

input:focus,
select:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 2px rgba(143, 190, 230, .25)
}

.row-4 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px
}

.auto-value {
    background: rgba(120, 194, 179, .1);
    border: 1px dashed var(--green);
    border-radius: var(--radius);
    padding: 9px 12px;
    font-size: 16px;
    font-weight: 700;
    color: var(--green)
}

/* Buttons */
.btn {
    padding: 8px 14px;
    border: none;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 13px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: .2s;
    color: #fff
}

.btn:active {
    transform: scale(.97)
}

.btn.blue {
    background: var(--blue)
}

.btn.blue:hover {
    background: #6891bf
}

.btn.green {
    background: var(--green)
}

.btn.green:hover {
    background: #5890ae
}

.btn.orange {
    background: var(--orange);
    color: #fff
}

.btn.orange:hover {
    background: #b8905e
}

.btn.red {
    background: var(--red);
    padding: 5px 8px;
    font-size: 11px
}

.btn.red:hover {
    background: #ad6a6a
}

.btn.sm {
    padding: 5px 10px;
    font-size: 12px
}

/* ══ PASTE ZONES ══ */
.paste-zone {
    margin-bottom: 14px
}

.paste-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 14px
}

.paste-drop {
    border: 2px dashed var(--paste-border);
    border-radius: 10px;
    padding: 14px 16px;
    text-align: center;
    cursor: pointer;
    transition: .3s;
    background: var(--paste-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-size: 12px;
    color: var(--muted);
    min-height: 56px
}

.paste-drop:hover,
.paste-drop.dragover {
    border-color: var(--purple);
    background: var(--paste-hover)
}

.paste-drop.active {
    border-color: var(--blue);
    background: rgba(124, 165, 212, .08);
    border-style: solid
}

.paste-drop i {
    color: var(--purple);
    font-size: 16px;
    flex-shrink: 0
}

.file-label {
    color: var(--blue);
    text-decoration: underline;
    cursor: pointer
}

.paste-status {
    margin-top: 8px
}

.paste-bar {
    background: rgba(0, 0, 0, .08);
    border-radius: 6px;
    height: 24px;
    position: relative;
    overflow: hidden
}

.paste-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--purple), var(--blue));
    border-radius: 6px;
    width: 0%;
    transition: width .3s
}

.paste-bar span {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 600;
    color: #fff;
    text-shadow: 0 1px 2px rgba(0, 0, 0, .3)
}

.paste-results {
    margin-top: 10px;
    background: rgba(155, 142, 200, .07);
    border: 1px solid rgba(155, 142, 200, .20);
    border-radius: 8px;
    padding: 10px;
    animation: fadeIn .4s ease
}

.paste-results-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px
}

.paste-results-head h4 {
    font-size: 12px;
    color: #8078a8
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(6px)
    }

    to {
        opacity: 1;
        transform: translateY(0)
    }
}

/* Editable OCR inputs */
.ocr-edit {
    width: 70px;
    padding: 4px 6px !important;
    font-size: 12px !important;
    text-align: center;
    background: rgba(155, 142, 200, .08) !important;
    border: 1px solid rgba(155, 142, 200, .30) !important;
    border-radius: 5px !important;
    color: var(--text) !important
}

.ocr-edit:focus {
    border-color: var(--purple) !important;
    box-shadow: 0 0 0 2px rgba(155, 142, 200, .22) !important
}

/* Inline edit inputs in template table */
.tpl-edit {
    padding: 4px 6px !important;
    font-size: 12px !important;
    text-align: center;
    background: transparent !important;
    border: 1px solid rgba(100, 120, 160, .15) !important;
    border-radius: 5px !important;
    color: var(--text) !important;
    transition: .2s
}

.tpl-edit:hover {
    border-color: rgba(124, 165, 212, .4) !important;
    background: rgba(124, 165, 212, .05) !important
}

.tpl-edit:focus {
    border-color: var(--blue) !important;
    box-shadow: 0 0 0 2px rgba(124, 165, 212, .22) !important;
    background: rgba(255, 255, 255, .9) !important
}

.tpl-edit-name {
    text-align: left !important;
    font-weight: 600 !important
}

.tpl-edit-dim {
    font-size: 11px !important;
    color: var(--muted) !important
}

/* Template form */
.manual-label {
    font-size: 13px;
    color: var(--muted);
    margin: 14px 0 10px;
    border-top: 1px dashed var(--border);
    padding-top: 14px
}

.tpl-form {
    display: grid;
    grid-template-columns: 1fr repeat(3, 80px) 90px 90px auto auto;
    gap: 8px;
    margin-bottom: 14px;
    align-items: end
}

.auto-cbm {
    padding: 9px 10px;
    font-size: 12px;
    font-weight: 600;
    color: var(--green);
    background: rgba(123, 184, 168, .08);
    border: 1px dashed rgba(123, 184, 168, .30);
    border-radius: var(--radius);
    white-space: nowrap;
    text-align: center
}

/* Tables */
.tbl {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px
}

.tbl th,
.tbl td {
    padding: 8px 10px;
    text-align: left;
    border-bottom: 1px solid var(--border)
}

.tbl th {
    background: rgba(0, 0, 0, .03);
    color: var(--muted);
    font-weight: 600;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .3px
}

.tbl tbody tr:hover {
    background: rgba(0, 0, 0, .02)
}

.tfoot-row td {
    font-size: 14px;
    border-top: 2px solid var(--border);
    padding-top: 10px
}

.tbl .empty {
    text-align: center;
    color: var(--muted);
    font-style: italic;
    padding: 20px
}

/* Status chips */
.chip {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 20px
}

.chip.ok {
    background: rgba(107, 163, 194, .18);
    color: #4a7f9e
}

.chip.warn {
    background: rgba(201, 160, 109, .18);
    color: #a0854a
}

.chip.err {
    background: rgba(192, 120, 120, .18);
    color: #a06060
}

/* Item Cards */
#items-wrap {
    display: flex;
    flex-direction: column;
    gap: 16px
}

.item-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden
}

.item-head {
    background: rgba(0, 0, 0, .025);
    padding: 10px 18px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border)
}

.item-head h3 {
    font-size: 15px;
    color: var(--blue)
}

.item-head-right {
    display: flex;
    align-items: center;
    gap: 10px
}

.target-qty-wrap {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--muted)
}

.target-qty-wrap input {
    width: 70px;
    text-align: center;
    padding: 5px 8px;
    font-size: 13px
}

.item-body {
    padding: 16px
}

.item-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px dashed rgba(0, 0, 0, .08)
}

.sbox {
    background: rgba(0, 0, 0, .025);
    padding: 8px 10px;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 4px
}

.sbox span {
    font-size: 10px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .3px
}

.sbox b {
    font-size: 15px
}

.sbox input {
    width: 100%;
    font-size: 13px;
    padding: 6px 8px;
    background: rgba(143, 190, 230, .1);
    border-color: rgba(143, 190, 230, .3)
}

/* Validation */
.validation-panel {
    border-top: 3px solid var(--blue)
}

.val-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px
}

.vc {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: .3s
}

.vc.match {
    border-color: var(--green);
    box-shadow: 0 0 12px rgba(107, 163, 194, .2)
}

.vc.miss {
    border-color: var(--red);
    box-shadow: 0 0 12px rgba(192, 120, 120, .2)
}

.vc-head {
    background: rgba(0, 0, 0, .03);
    padding: 10px 12px;
    font-size: 13px;
    font-weight: 600;
    display: flex;
    justify-content: space-between;
    align-items: center
}

.tag {
    padding: 2px 7px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 700;
    background: #b0aab8;
    color: #fff
}

.vc.match .tag {
    background: var(--green)
}

.vc.miss .tag {
    background: var(--red)
}

.vc-row {
    display: flex;
    justify-content: space-between;
    padding: 6px 12px;
    font-size: 12px
}

.vc-row:last-child {
    border-top: 1px solid var(--border);
    padding-top: 8px;
    margin-top: 2px
}

/* Export Actions */
.export-actions {
    display: flex;
    gap: 10px;
    margin-top: 16px;
    justify-content: center;
    padding-top: 16px;
    border-top: 1px solid var(--border);
}

.export-actions .btn {
    padding: 10px 20px;
    font-size: 14px
}

/* Responsive */
@media(max-width:900px) {
    .app { padding: 12px }
    .card { padding: 16px }
    .app-header h1 { font-size: 22px }

    .tpl-form {
        grid-template-columns: 1fr 1fr 1fr;
        gap: 6px
    }

    .val-grid,
    .paste-row {
        grid-template-columns: 1fr
    }

    .item-grid {
        grid-template-columns: repeat(2, 1fr)
    }

    .item-head {
        flex-direction: column;
        gap: 10px;
        align-items: flex-start
    }

    .item-head-right {
        width: 100%;
        flex-wrap: wrap;
        gap: 8px
    }

    .card-head {
        flex-direction: column;
        gap: 10px;
        align-items: flex-start
    }

    .head-actions {
        width: 100%
    }

    .head-actions .btn {
        flex: 1;
        justify-content: center
    }

    /* Horizontal scroll for tables on smaller screens */
    .tbl { display: block; overflow-x: auto; -webkit-overflow-scrolling: touch }
    .tbl thead, .tbl tbody, .tbl tfoot { min-width: 600px; display: table; width: 100% }

    .export-actions {
        flex-direction: column;
        align-items: stretch
    }
    .export-actions .btn {
        justify-content: center
    }
}

@media(max-width:500px) {
    .app { padding: 8px }
    .card { padding: 12px }
    .app-header h1 { font-size: 18px }
    .app-header p { font-size: 11px }

    .val-grid,
    .item-grid {
        grid-template-columns: 1fr
    }

    .row-4 {
        grid-template-columns: 1fr
    }

    .tpl-form {
        grid-template-columns: 1fr 1fr;
        gap: 6px
    }

    .target-qty-wrap {
        width: 100%
    }

    .item-head h3 {
        font-size: 14px
    }

    .paste-drop {
        flex-direction: column;
        padding: 12px;
        font-size: 11px;
        min-height: 48px
    }

    .paste-drop i { font-size: 20px }

    .theme-toggle {
        width: 36px;
        height: 36px;
        font-size: 14px
    }
}

/* Theme Toggle */
.theme-toggle {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: 50px;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 18px;
    color: var(--muted);
    transition: all .3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, .08)
}

.theme-toggle:hover {
    background: var(--blue);
    color: #fff;
    border-color: var(--blue);
    transform: translateY(-50%) scale(1.08);
    box-shadow: 0 4px 16px rgba(143, 190, 230, .3)
}

.theme-toggle:active {
    transform: translateY(-50%) scale(.95)
}

/* Smooth theme transitions */
body,
.card,
.item-card,
.item-head,
.vc,
.vc-head,
.sbox,
.paste-drop,
input,
select,
.btn,
.tbl th {
    transition: background .3s ease, color .3s ease, border-color .3s ease, box-shadow .3s ease
}

/* Dark mode specific overrides */
[data-theme="dark"] .item-head {
    background: rgba(255, 255, 255, .03)
}

[data-theme="dark"] .sbox {
    background: rgba(255, 255, 255, .04)
}

[data-theme="dark"] .tbl th {
    background: rgba(255, 255, 255, .04)
}

[data-theme="dark"] .tbl tbody tr:hover {
    background: rgba(255, 255, 255, .03)
}

[data-theme="dark"] .vc-head {
    background: rgba(255, 255, 255, .04)
}

[data-theme="dark"] .paste-results {
    background: rgba(165, 201, 232, .06);
    border-color: rgba(165, 201, 232, .15)
}

[data-theme="dark"] .ocr-edit {
    background: rgba(165, 201, 232, .08) !important;
    border-color: rgba(165, 201, 232, .20) !important
}

[data-theme="dark"] .tpl-edit:focus {
    background: rgba(37, 44, 61, .95) !important
}

[data-theme="dark"] .auto-cbm {
    background: rgba(124, 196, 168, .08);
    border-color: rgba(124, 196, 168, .25)
}

[data-theme="dark"] .paste-bar {
    background: rgba(255, 255, 255, .08)
}

[data-theme="dark"] .tag {
    background: #636878
}

[data-theme="dark"] .paste-results-head h4 {
    color: var(--muted)
}

[data-theme="dark"] .card {
    box-shadow: 0 4px 24px rgba(0, 0, 0, .20)
}

[data-theme="dark"] .sbox input {
    background: rgba(165, 201, 232, .08);
    border-color: rgba(165, 201, 232, .20)
}

[data-theme="dark"] .chip.ok {
    background: rgba(124, 196, 168, .15);
    color: #7cc4a8
}

[data-theme="dark"] .chip.warn {
    background: rgba(212, 169, 106, .15);
    color: #d4a96a
}

[data-theme="dark"] .chip.err {
    background: rgba(212, 106, 106, .15);
    color: #d46a6a
}

/* ══════════════════════════════════════════════
   CUSTOM MODAL (alert / confirm)
   ══════════════════════════════════════════════ */
.modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, .45);
    backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity .25s ease
}

.modal-overlay.active {
    opacity: 1;
    pointer-events: auto
}

.modal-box {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px 32px;
    min-width: 320px;
    max-width: 440px;
    width: 90vw;
    box-shadow: 0 16px 48px rgba(0, 0, 0, .18);
    backdrop-filter: blur(16px);
    transform: scale(.9) translateY(10px);
    transition: transform .3s cubic-bezier(.34, 1.56, .64, 1);
    text-align: center
}

.modal-overlay.active .modal-box {
    transform: scale(1) translateY(0)
}

.modal-icon {
    font-size: 40px;
    margin-bottom: 12px
}

.modal-icon.success { color: var(--green) }
.modal-icon.error { color: var(--red) }
.modal-icon.warning { color: var(--orange) }
.modal-icon.info { color: var(--blue) }

.modal-message {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text);
    margin-bottom: 20px;
    word-break: break-word
}

.modal-actions {
    display: flex;
    gap: 10px;
    justify-content: center
}

.modal-btn-ok {
    background: var(--blue) !important;
    color: #fff !important;
    padding: 10px 24px !important;
    font-size: 14px !important;
    border-radius: 10px !important;
    font-weight: 600 !important;
    min-width: 100px
}

.modal-btn-ok:hover {
    background: #6891bf !important;
    transform: scale(1.02)
}

.modal-btn-cancel {
    background: transparent !important;
    color: var(--muted) !important;
    border: 1px solid var(--border) !important;
    padding: 10px 24px !important;
    font-size: 14px !important;
    border-radius: 10px !important;
    font-weight: 600 !important;
    min-width: 100px
}

.modal-btn-cancel:hover {
    background: rgba(0, 0, 0, .05) !important;
    color: var(--text) !important
}

/* ══ MODAL DUS ══ */
.modal-dus {
    text-align: left
}

.modal-dus h3 {
    font-size: 17px;
    font-weight: 700;
    color: var(--blue);
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 8px
}

.modal-field {
    margin-bottom: 14px
}

.modal-field label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: .3px
}

.modal-field select,
.modal-field input {
    width: 100%;
    padding: 10px 14px;
    font-size: 14px
}

.modal-dus-preview {
    font-size: 12px;
    font-weight: 600;
    color: var(--green);
    background: rgba(123, 184, 168, .08);
    border: 1px dashed rgba(123, 184, 168, .30);
    border-radius: 8px;
    padding: 10px 14px;
    margin-bottom: 18px;
    min-height: 38px;
    display: flex;
    align-items: center;
    justify-content: center
}

.modal-dus .modal-actions {
    justify-content: flex-end;
    padding-top: 8px;
    border-top: 1px solid var(--border)
}

/* Dark mode modal overrides */
[data-theme="dark"] .modal-overlay {
    background: rgba(0, 0, 0, .60)
}

[data-theme="dark"] .modal-box {
    box-shadow: 0 16px 48px rgba(0, 0, 0, .40)
}

[data-theme="dark"] .modal-btn-cancel:hover {
    background: rgba(255, 255, 255, .06) !important
}

/* Freight reasonableness warning */
.freight-warn {
    margin-top: 8px;
    padding: 8px 12px;
    font-size: 11px;
    color: var(--orange);
    background: rgba(201, 163, 95, .08);
    border-left: 3px solid var(--orange);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    gap: 6px;
    animation: fadeIn .3s ease
}